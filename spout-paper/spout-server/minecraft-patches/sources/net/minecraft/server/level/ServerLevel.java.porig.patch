+            entity.postTick(); // CraftBukkit
+            } else {
+                entity.setDeltaMovement(Vec3.ZERO);
+                entity.inactiveTick();
+                // copied from inside of if (isPassenger()) of passengerTick, but that ifPassenger is unnecessary
+                vehicle.positionRider(entity);
